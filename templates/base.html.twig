<!doctype html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}DataBridge Hub{% endblock %}</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f6f7f9;
            color: #1f2937;
        }

        .topbar {
            background: #111827;
            color: white;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .topbar a {
            color: white;
            text-decoration: none;
            margin-left: 16px;
        }

        .container {
            max-width: 960px;
            margin: 32px auto;
            padding: 0 16px;
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
        }

        .form-row {
            margin-bottom: 16px;
        }

        label {
            display: block;
            margin-bottom: 6px;
            font-weight: 600;
        }

        input {
            width: 100%;
            box-sizing: border-box;
            padding: 10px 12px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
        }

        button,
        .button {
            display: inline-block;
            border: 0;
            border-radius: 8px;
            padding: 10px 16px;
            background: #2563eb;
            color: white;
            cursor: pointer;
            text-decoration: none;
            font-size: 14px;
        }

        .button-secondary {
            background: #4b5563;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 16px;
        }

        .alert-success {
            background: #dcfce7;
            color: #166534;
        }

        .alert-error {
            background: #fee2e2;
            color: #991b1b;
        }

        .error-list {
            color: #991b1b;
            margin-top: 6px;
            font-size: 14px;
        }

        .logout-form {
            display: inline;
        }

        .logout-form button {
            background: transparent;
            padding: 0;
            margin-left: 16px;
            color: white;
            text-decoration: underline;
        }
    </style>
</head>
<body>
<header class="topbar">
    <div>
        <a href="{{ path('app_dashboard') }}">DataBridge Hub</a>
    </div>

    <nav>
        {% if app.user %}
            <a href="{{ path('app_dashboard') }}">Dashboard</a>
            <a href="{{ path('app_company_index') }}">Компании</a>

            <span>{{ app.user.userIdentifier }}</span>

            <form class="logout-form" method="post" action="{{ path('app_logout') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                <button type="submit">Выйти</button>
            </form>
        {% else %}
            <a href="{{ path('app_login') }}">Войти</a>
            <a href="{{ path('app_register') }}">Регистрация</a>
        {% endif %}
    </nav>
</header>

<main class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-error">{{ message }}</div>
    {% endfor %}

    {% block body %}{% endblock %}
</main>
</body>
</html>
