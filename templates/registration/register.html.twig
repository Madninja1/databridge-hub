{% extends 'base.html.twig' %}

{% block title %}Регистрация | DataBridge Hub{% endblock %}

{% block body %}
    <div class="card">
        <h1>Регистрация</h1>

        {{ form_start(registrationForm) }}
        <div class="form-row">
            {{ form_label(registrationForm.email) }}
            {{ form_widget(registrationForm.email) }}
            <div class="error-list">
                {{ form_errors(registrationForm.email) }}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(registrationForm.plainPassword) }}
            {{ form_widget(registrationForm.plainPassword) }}
            <div class="error-list">
                {{ form_errors(registrationForm.plainPassword) }}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(registrationForm.firstName) }}
            {{ form_widget(registrationForm.firstName) }}
            <div class="error-list">
                {{ form_errors(registrationForm.firstName) }}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(registrationForm.lastName) }}
            {{ form_widget(registrationForm.lastName) }}
            <div class="error-list">
                {{ form_errors(registrationForm.lastName) }}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(registrationForm.companyName) }}
            {{ form_widget(registrationForm.companyName) }}
            <div class="error-list">
                {{ form_errors(registrationForm.companyName) }}
            </div>
        </div>

        <button type="submit">Создать аккаунт</button>
        {{ form_end(registrationForm) }}
    </div>
{% endblock %}
